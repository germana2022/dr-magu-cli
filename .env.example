REPO_AGENT_WORKSPACE=.
REPO_AGENT_CONFIG=config/orchestration.yaml

LLM_PROVIDER=opencode
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXX
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.1

# v2.1.0 Operational MCP Runtime
RESEARCH_PROVIDER=auto
BRAVE_API_KEY=
GITHUB_TOKEN=

MCP_BRAVE_SEARCH_ENABLED=false
MCP_BRAVE_SEARCH_AUTO_START=true
MCP_BRAVE_SEARCH_COMMAND=npx
MCP_BRAVE_SEARCH_ARGS=["-y", "@modelcontextprotocol/server-brave-search"]

MCP_PLAYWRIGHT_ENABLED=false
MCP_PLAYWRIGHT_AUTO_START=true
MCP_PLAYWRIGHT_COMMAND=npx
MCP_PLAYWRIGHT_ARGS=["-y", "@playwright/mcp"]

MCP_GITHUB_ENABLED=false
MCP_GITHUB_AUTO_START=true
MCP_GITHUB_COMMAND=npx
MCP_GITHUB_ARGS=["-y", "@modelcontextprotocol/server-github"]

MCP_FILESYSTEM_ENABLED=false
MCP_FILESYSTEM_AUTO_START=true
MCP_FILESYSTEM_COMMAND=npx
MCP_FILESYSTEM_ARGS=["-y", "@modelcontextprotocol/server-filesystem", "."]
